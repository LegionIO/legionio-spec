        "properties": {
          "state": {
            "type": "string",
            "description": "Target lifecycle state",
            "example": "paused"
          },
          "by": {
            "type": "string",
            "description": "Identity performing the transition (MSID or service name)",
            "example": "jane.doe@example.com"
          },
          "reason": {
            "type": "string",
            "description": "Human-readable reason for the transition",
            "example": "Scheduled maintenance window"
          },
          "governance_override": {
            "type": "boolean",
            "default": false,
            "description": "Override governance gate (requires elevated authority)"
          },
          "authority_verified": {
            "type": "boolean",
            "default": false,
            "description": "Confirm that the caller has verified authority for this transition"
          }
        }
