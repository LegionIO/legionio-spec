          },
          "extension_name": {
            "type": "string",
            "example": "lex-invoice"
          },
          "entra_app_id": {
            "type": "string",
            "example": "00000000-0000-0000-0000-000000000001"
          },
          "owner_msid": {
            "type": "string",
            "example": "jane.doe@example.com"
          },
          "owner_name": {
            "type": [
              "string",
              "null"
            ],
            "example": "Jane Doe"
          },
          "business_role": {
            "type": [
              "string",
              "null"
            ],
            "example": "Senior Engineer"
          },
          "risk_tier": {
            "type": [
              "string",
              "null"
            ],
            "example": "tier-2"
          },
          "team": {
            "type": [
