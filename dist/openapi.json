{
  "openapi": "3.1.0",
  "info": {
    "title": "LegionIO REST API",
    "description": "Async job engine and digital worker platform REST API. All routes are under the /api/ prefix. Success responses wrap data in { data: ..., meta: { timestamp, node } }. Error responses use { error: { code, message }, meta: { timestamp, node } }.\n",
    "version": "1.4.122",
    "contact": {
      "name": "LegionIO",
      "url": "https://github.com/LegionIO/LegionIO"
    },
    "license": {
      "name": "Apache-2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0"
    }
  },
  "servers": [
    {
      "url": "http://localhost:4567",
      "description": "Local Legion daemon"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    },
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health and readiness probes"
    },
    {
