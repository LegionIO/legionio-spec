      "description": "Task management and execution"
    },
    {
      "name": "Extensions",
      "description": "Extension, runner, and function discovery"
    },
    {
      "name": "Nodes",
      "description": "Node registry"
    },
    {
      "name": "Schedules",
      "description": "Cron/interval schedule management"
    },
    {
      "name": "Relationships",
      "description": "Task relationships"
    },
    {
      "name": "Chains",
      "description": "Task chains (stub)"
    },
    {
      "name": "Settings",
      "description": "Runtime configuration"
    },
    {
      "name": "Events",
      "description": "SSE event stream and recent event buffer"
    },
    {
      "name": "Transport",
      "description": "RabbitMQ transport status and publish"
    },
    {
      "name": "Hooks",
      "description": "Extension webhook endpoints"
    },
    {
      "name": "Lex",
      "description": "Auto-registered LEX runner routes"
    },
    {
      "name": "Workers",
      "description": "Digital worker lifecycle management"
    },
    {
      "name": "Teams",
      "description": "Team-level worker and cost views"
    },
    {
      "name": "LLM",
      "description": "LLM inference"
    },
    {
      "name": "Auth",
      "description": "Authentication and token management"
    },
    {
      "name": "RBAC",
      "description": "Role-based access control"
    },
    {
      "name": "Audit",
      "description": "Audit log"
    },
    {
      "name": "Capacity",
      "description": "Workforce capacity"
    },
    {
      "name": "Tenants",
      "description": "Multi-tenant management"
    },
    {
      "name": "Catalog",
      "description": "Extension catalog"
    },
    {
      "name": "Webhooks",
      "description": "Webhook subscriptions"
    },
    {
      "name": "Marketplace",
      "description": "Extension marketplace"
    },
    {
      "name": "Governance",
      "description": "Approval workflows"
    },
    {
      "name": "Prompts",
      "description": "Prompt management"
    },
    {
      "name": "Coldstart",
      "description": "Cold-start memory ingestion"
    },
    {
      "name": "Gaia",
      "description": "Gaia cognitive layer"
    },
    {
      "name": "GraphQL",
      "description": "GraphQL API endpoint"
    },
    {
      "name": "ACP",
      "description": "Agent Communication Protocol"
    },
    {
      "name": "Metrics",
      "description": "Prometheus metrics"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Health check",
        "description": "Returns ok status and version. Skips auth middleware.",
        "operationId": "getHealth",
        "security": [],
        "responses": {
          "200": {
            "description": "Healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "status": {
                          "type": "string",
                          "example": "ok"
                        },
                        "version": {
                          "type": "string",
                          "example": "1.4.122"
                        }
                      }
                    },
                    "meta": {
                      "$ref": "#/components/schemas/Meta"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/ready": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Readiness check",
        "description": "Returns readiness status for all components. Returns 503 if not ready. Skips auth middleware.\n",
        "operationId": "getReady",
        "security": [],
        "responses": {
          "200": {
            "description": "Ready",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "ready": {
                          "type": "boolean"
                        },
                        "components": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "boolean"
                          }
                        }
                      }
                    },
                    "meta": {
                      "$ref": "#/components/schemas/Meta"
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Not ready",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Legion-issued JWT token (worker or human scope)"
      },
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Pre-shared API key"
      }
    },
    "schemas": {
      "Meta": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "node": {
            "type": "string"
          }
        },
        "required": [
          "timestamp",
          "node"
        ]
      },
      "MetaCollection": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "node": {
            "type": "string"
          },
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          }
        },
        "required": [
          "timestamp",
          "node",
          "total",
          "limit",
          "offset"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": [
              "code",
              "message"
            ]
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        },
        "required": [
          "error",
          "meta"
        ]
      },
      "DeletedResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "deleted": {
                "type": "boolean"
              }
            }
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        },
        "required": [
          "data",
          "meta"
        ]
      },
      "TaskObject": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 42
          },
          "function_id": {
            "type": "integer",
            "example": 7
          },
          "status": {
            "type": "string",
            "example": "complete"
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          },
          "worker_id": {
            "type": [
              "string",
              "null"
            ],
            "example": "worker-abc123"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "metering": {
            "$ref": "#/components/schemas/TaskMetering"
          }
        },
        "required": [
          "id",
          "function_id",
          "status",
          "created_at",
          "updated_at"
        ]
      },
      "TaskMetering": {
        "type": "object",
        "description": "Aggregated LLM token usage for this task. Present only when metering records exist.",
        "properties": {
          "total_tokens": {
            "type": "integer",
            "example": 1200
          },
          "input_tokens": {
            "type": "integer",
            "example": 800
          },
          "output_tokens": {
            "type": "integer",
            "example": 400
          },
          "thinking_tokens": {
            "type": "integer",
            "example": 0
          },
          "total_calls": {
            "type": "integer",
            "example": 3
          },
          "avg_latency_ms": {
            "type": "number",
            "format": "float",
            "example": 342.5
          },
          "provider": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "bedrock"
            ]
          },
          "model": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "claude-3-5-sonnet-20241022"
            ]
          }
        },
        "required": [
          "total_tokens",
          "input_tokens",
          "output_tokens",
          "thinking_tokens",
          "total_calls",
          "avg_latency_ms",
          "provider",
          "model"
        ]
      },
      "TaskInput": {
        "type": "object",
        "required": [
          "runner_class",
          "function"
        ],
        "properties": {
          "runner_class": {
            "type": "string",
            "description": "Fully qualified runner class name",
            "example": "Legion::Extensions::Http::Runners::Http"
          },
          "function": {
            "type": "string",
            "description": "Runner function name to invoke",
            "example": "get"
          },
          "check_subtask": {
            "type": "boolean",
            "default": true,
            "description": "Whether to check for an existing subtask before creating a new one"
          },
          "generate_task": {
            "type": "boolean",
            "default": true,
            "description": "Whether to persist a task record for this invocation"
          }
        },
        "additionalProperties": true
      },
      "TaskResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TaskObject"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        },
        "required": [
          "data",
          "meta"
        ]
      },
      "TaskCollectionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaskObject"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/MetaCollection"
          }
        },
        "required": [
          "data",
          "meta"
        ]
      },
      "TaskLogObject": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "task_id": {
            "type": "integer",
            "example": 42
          },
          "level": {
            "type": "string",
            "example": "info"
          },
          "message": {
            "type": "string",
            "example": "Task started"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "task_id",
          "level",
          "message",
          "created_at"
        ]
      },
      "TaskLogCollectionResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaskLogObject"
            }
          },
          "meta": {
            "$ref": "#/components/schemas/MetaCollection"
          }
        },
        "required": [
          "data",
          "meta"
        ]
      },
      "TaskCreatedObject": {
        "type": "object",
        "description": "Task creation result returned by Ingress.",
        "properties": {
          "task_id": {
            "type": "integer",
            "example": 42
          }
        },
        "additionalProperties": true
      },
      "TaskCreatedResponse": {
        "type": "object",
        "description": "Response from POST /api/tasks — task_id and status from Ingress",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TaskCreatedObject"
          },
          "meta": {
            "$ref": "#/components/schemas/Meta"
          }
        },
        "required": [
          "data",
          "meta"
        ]
      },
      "WorkerObject": {
        "type": "object",
        "properties": {
          "worker_id": {
            "type": "string",
            "example": "worker-abc123"
          },
          "name": {
            "type": "string",
