            "example": "platform"
          },
          "lifecycle_state": {
            "type": "string",
            "example": "active"
          },
          "manager_msid": {
            "type": [
              "string",
              "null"
            ],
            "example": "manager@example.com"
          },
          "health_status": {
            "type": [
              "string",
              "null"
